---
import BrandLogo from '../components/BrandLogo.astro';
import LineIcon from '../components/LineIcon.astro';

const trackables = [
	{
		title: 'Medications',
		copy: 'Prescriptions, antidepressants, thyroid medication, birth control, and hormone therapy.',
		icon: 'prescription',
		color: 'red-soft',
	},
	{
		title: 'Peptides',
		copy: 'Keep prescribed peptide and injectable routines alongside the rest of your day.',
		icon: 'peptide',
		color: 'warm-white',
	},
	{
		title: 'Supplements',
		copy: 'Magnesium, vitamin D, iron, probiotics, creatine, melatonin, electrolytes, and more.',
		icon: 'supplement',
		color: 'red-soft',
	},
	{
		title: 'Symptoms & signals',
		copy: 'Mood, sleep, energy, appetite, discomfort, and the observations that matter to you.',
		icon: 'symptoms',
		color: 'warm-white',
	},
	{
		title: 'Cycles & life stages',
		copy: 'Menstrual-cycle notes, perimenopause, menopause, and changing routines over time.',
		icon: 'cycle',
		color: 'red-soft',
	},
	{
		title: 'Appointment notes',
		copy: 'Gather a clearer history of what you took and what you noticed for your next conversation.',
		icon: 'appointment',
		color: 'warm-white',
	},
];

const timeline = [
	{ time: '8:00', period: 'AM', title: 'Antidepressant', type: 'Medication', status: 'done', tone: 'deep' },
	{ time: '9:00', period: 'AM', title: 'Magnesium', type: 'Supplement', status: 'done', tone: 'primary' },
	{ time: '6:00', period: 'PM', title: 'Peptide dose', type: 'Routine', status: 'upcoming', tone: 'bright' },
];

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="MyPeppers brings peptide routines, medications, supplements, symptoms, and women’s health changes together in one clear and private timeline." />
		<meta name="theme-color" content="#C9363E" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>MyPeppers — Your whole routine, in one private place</title>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<header class="site-header">
			<a class="brand" href="#top" aria-label="MyPeppers home"><BrandLogo size={38} /></a>
			<nav aria-label="Main navigation">
				<a href="#track">What you can track</a>
				<a href="#patterns">Why it helps</a>
				<a href="#privacy">Privacy</a>
			</nav>
			<a class="button button-small" href="#waitlist">Join the waitlist <span aria-hidden="true">↗</span></a>
		</header>

		<main id="main">
			<section class="hero" id="top">
				<div class="hero-copy">
					<p class="eyebrow"><span aria-hidden="true"></span>Health tracking, designed with women in mind</p>
					<h1>Your whole routine,<br /><em>in one private place.</em></h1>
					<p class="hero-lede">Track peptides, prescriptions, supplements, symptoms, cycle changes, sleep, mood, and more—without juggling multiple apps or scattered notes.</p>
					<div class="hero-actions">
						<a class="button" href="#waitlist">Join the waitlist <span aria-hidden="true">↗</span></a>
						<a class="text-link" href="#track">Explore what you can track <span aria-hidden="true">↓</span></a>
					</div>
					<p class="microcopy"><span aria-hidden="true">◇</span> Private by design · You choose what to track</p>
				</div>

				<div class="product-stage" aria-label="Preview of a daily timeline in the MyPeppers app">
					<div class="hero-brand-symbol"><BrandLogo iconOnly size={122} /></div>
					<div class="halo halo-one"></div><div class="halo halo-two"></div>
					<div class="context-card cycle-card"><span class="context-icon">◔</span><div><small>CYCLE NOTE</small><strong>Day 18 · Energy steady</strong></div></div>
					<div class="context-card privacy-card"><span class="context-icon">◇</span><div><small>YOUR SPACE</small><strong>Private by design</strong></div></div>
					<div class="phone">
						<div class="phone-top"><span>9:41</span><b></b><span>● ●</span></div>
						<div class="app-head">
							<div><small>MONDAY, JULY 13</small><h2>Today</h2></div>
							<div class="avatar">M</div>
						</div>
						<div class="day-summary"><span>3</span><div><small>ROUTINES TODAY</small><strong>One clear view of your day</strong></div><i>•••</i></div>
						<div class="timeline-label"><strong>Your timeline</strong><span>＋ Add</span></div>
						<div class="timeline">
							{timeline.map((item) => (
								<div class="timeline-row">
									<div class="time"><strong>{item.time}</strong><small>{item.period}</small></div>
									<div class:list={['timeline-node', item.status, item.tone]}><span>{item.status === 'done' ? '✓' : ''}</span></div>
									<div class="timeline-name"><strong>{item.title}</strong><small>{item.type}</small></div>
									<button type="button" aria-label={`More options for ${item.title}`}>•••</button>
								</div>
							))}
						</div>
						<div class="checkin-card">
							<div><small>EVENING CHECK-IN</small><strong>How did today feel?</strong></div>
							<div class="checkin-tags"><span>Mood</span><span>Energy</span><span>Symptoms</span></div>
						</div>
						<div class="app-nav"><span class="selected">⌂<small>Today</small></span><span>◷<small>Timeline</small></span><span>⌁<small>Patterns</small></span><span>○<small>You</small></span></div>
					</div>
				</div>
			</section>

			<section class="principles" aria-label="MyPeppers product principles">
				<p><span>01</span>Everything in one timeline</p>
				<p><span>02</span>Built around changing needs</p>
				<p><span>03</span>Private and user-controlled</p>
			</section>

			<section class="section track-section" id="track">
				<div class="section-intro">
					<div><p class="kicker">THE COMPLETE PICTURE</p><h2>Everything you take.<br />Everything you <em>notice.</em></h2></div>
					<p>Your routines are connected. Your tracker should be too. MyPeppers gives each detail a place without assuming what your health goals should be.</p>
				</div>
				<div class="track-grid">
					{trackables.map((item) => (
						<article class={`track-card ${item.color}`}>
						<div class="line-icon"><LineIcon name={item.icon} size={24} /></div>
							<h3>{item.title}</h3>
							<p>{item.copy}</p>
						</article>
					))}
				</div>
			</section>

			<section class="connected" id="patterns">
				<div class="connected-copy">
					<p class="kicker">CONTEXT CHANGES EVERYTHING</p>
					<h2>See your routine<br /><em>more clearly.</em></h2>
					<p>Sleep can shape mood. A new routine can overlap with cycle changes. A symptom can appear before an appointment and disappear by the time you get there. MyPeppers keeps the details together so you can look back with more context.</p>
					<ul>
						<li><span>✓</span><div><strong>One calm daily timeline</strong><small>See routines and observations in the order they happened.</small></div></li>
						<li><span>✓</span><div><strong>Patterns without conclusions</strong><small>Notice timing and repetition without presenting correlation as medical certainty.</small></div></li>
						<li><span>✓</span><div><strong>Clearer appointment notes</strong><small>Prepare a useful summary to discuss with a qualified clinician.</small></div></li>
					</ul>
				</div>
				<div class="pattern-board" aria-label="Example weekly pattern view">
					<div class="board-head"><div><small>WEEKLY VIEW</small><strong>Sleep & energy</strong></div><span>Jul 6–12</span></div>
					<div class="chart-labels"><span>Steady</span><span>Low</span></div>
					<div class="chart">
						<div class="grid-line one"></div><div class="grid-line two"></div><div class="grid-line three"></div>
						<svg viewBox="0 0 520 190" preserveAspectRatio="none" aria-hidden="true">
							<path class="sleep-line" d="M2 88 C42 67 65 78 90 66 S145 47 175 62 S225 112 258 94 S312 38 350 58 S405 125 440 92 S486 58 518 70" />
							<path class="energy-line" d="M2 132 C48 119 68 140 105 123 S160 95 195 104 S260 149 295 122 S352 87 385 99 S441 138 478 112 S505 92 518 96" />
						</svg>
					</div>
					<div class="chart-days"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div>
					<div class="chart-legend"><span><i class="sleep"></i>Sleep quality</span><span><i class="energy"></i>Energy</span></div>
					<div class="board-note"><span>◇</span><p><strong>A note, not a conclusion</strong><small>Your energy entries appeared steadier on days following longer sleep. Keep tracking to add context.</small></p></div>
				</div>
			</section>

			<section class="life-stages section">
				<div class="life-art" aria-hidden="true">
					<div class="rhythm r-one"></div><div class="rhythm r-two"></div><div class="rhythm r-three"></div>
					<div class="stage-note note-one"><LineIcon name="sleep" size={20} /><span>Sleep</span><strong>7h 42m</strong><small>Restful</small></div>
					<div class="stage-note note-two"><LineIcon name="cycle" size={20} /><span>Cycle</span><strong>Day 18</strong><small>Personal note added</small></div>
					<div class="stage-note note-three"><LineIcon name="mood" size={20} /><span>Evening</span><strong>Energy steady</strong><small>Mood · Calm</small></div>
				</div>
				<div class="life-copy">
					<p class="kicker">MADE FOR CHANGE</p>
					<h2>Built around women’s<br /><em>changing health needs.</em></h2>
					<p>Health routines are not static. MyPeppers is designed to support the details you choose to track across menstrual cycles, perimenopause, menopause, medication changes, and everyday life—without assuming every woman has the same experience.</p>
					<a class="text-link" href="#waitlist">Help shape the beta <span aria-hidden="true">↗</span></a>
				</div>
			</section>

			<section class="privacy section" id="privacy">
				<div class="privacy-heading">
					<div class="privacy-icon"><LineIcon name="privacy" size={26} /></div>
					<p class="kicker">YOUR INFORMATION, YOUR TERMS</p>
					<h2>Private by <em>design.</em></h2>
					<p>Health information is personal. MyPeppers is designed around user control, clear boundaries, and a simple principle: your tracker should work for you.</p>
				</div>
				<div class="privacy-grid">
					<article><span>01</span><h3>You choose what to track</h3><p>Add only the routines and observations that are useful to you.</p></article>
					<article><span>02</span><h3>No medical overreach</h3><p>MyPeppers organizes your entries. It does not diagnose, prescribe, or recommend treatment.</p></article>
					<article><span>03</span><h3>Context you can use</h3><p>Prepare clearer notes for conversations with your care team, on your terms.</p></article>
				</div>
				<p class="medical-note"><span aria-hidden="true">i</span> MyPeppers is a tracking and organization tool. It is not a substitute for professional medical advice, diagnosis, or treatment.</p>
			</section>

			<section class="waitlist" id="waitlist">
				<div class="waitlist-copy">
					<p class="kicker">EARLY ACCESS</p>
					<h2>Your routines belong<br /><em>together.</em></h2>
					<p>Join the waitlist to hear when MyPeppers is ready for iOS or Android. No pressure, no noise—just thoughtful product updates.</p>
				</div>
				<form id="beta-form">
					<label>Email address<input required maxlength="254" type="email" name="email" placeholder="you@example.com" autocomplete="email" /></label>
					<fieldset>
						<legend>Which phone do you use?</legend>
						<label><input checked type="radio" name="platform" value="ios" /><span>Apple iOS</span></label>
						<label><input type="radio" name="platform" value="android" /><span>Android</span></label>
					</fieldset>
					<input type="hidden" name="source" value="website" />
					<button class="button" type="submit">Join the waitlist <span aria-hidden="true">↗</span></button>
					<p class="form-note" id="form-note" aria-live="polite">No spam. Just product updates and your beta invitation.</p>
				</form>
			</section>
		</main>

		<footer>
			<div class="footer-brand"><a class="brand" href="#top"><BrandLogo variant="light" size={38} /></a><p>See your routine more clearly.</p></div>
			<div class="footer-links"><div><strong>Explore</strong><a href="#track">What you can track</a><a href="#patterns">Why it helps</a><a href="#waitlist">Early access</a></div><div><strong>Trust</strong><a href="#privacy">Privacy</a><a href="#privacy">Terms</a><a href="mailto:hello@mypeppers.app">Support</a></div></div>
			<div class="footer-bottom"><small>© 2026 MyPeppers. All rights reserved.</small><small>Tracking support, not medical advice.</small></div>
		</footer>

		<script>
			const form = document.querySelector<HTMLFormElement>('#beta-form');
			const note = document.querySelector<HTMLParagraphElement>('#form-note');
			form?.addEventListener('submit', (event) => {
				event.preventDefault();
				if (!form.reportValidity() || !note) return;
				const data = new FormData(form);
				localStorage.setItem('mypeppers-beta-interest', JSON.stringify({
					email: data.get('email'),
					platform: data.get('platform'),
					source: data.get('source'),
				}));
				note.textContent = "Your interest is saved on this device. We'll see you in beta.";
				note.classList.add('success');
				const button = form.querySelector<HTMLButtonElement>('button');
				if (button) button.innerHTML = 'Interest saved <span aria-hidden="true">✓</span>';
			});
		</script>
	</body>
</html>

<style>
	:root {
		--red-primary: #c9363e;
		--red-deep: #8f1f28;
		--red-bright: #e64b52;
		--white: #ffffff;
		--warm-white: #fff9f8;
		--red-soft: #fcebec;
		--charcoal: #2b2526;
		--muted: #6f6466;
		--border: #eadddd;
		--surface: var(--white);
		--shadow: 0 24px 70px rgba(143, 31, 40, 0.1);
		--sans: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		--serif: Iowan Old Style, Palatino Linotype, Book Antiqua, Palatino, Georgia, serif;
	}

	* { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; background: var(--warm-white); color: var(--charcoal); font-family: var(--sans); -webkit-font-smoothing: antialiased; }
	a { color: inherit; text-decoration: none; }
	button, input { font: inherit; }
	:focus-visible { outline: 3px solid var(--red-bright); outline-offset: 4px; }
	.skip-link { position: fixed; z-index: 100; top: 12px; left: 12px; padding: 11px 16px; background: var(--red-deep); color: white; transform: translateY(-160%); transition: transform .2s; }
	.skip-link:focus { transform: translateY(0); }

	.site-header { position: absolute; z-index: 10; width: 100%; height: 88px; padding: 0 clamp(24px, 5vw, 76px); display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); background: rgba(255, 255, 255, .72); backdrop-filter: blur(10px); }
	.brand { display: inline-flex; }
	nav { display: flex; gap: 34px; font-size: 13px; font-weight: 650; color: var(--charcoal); }
	nav a, .footer-links a { transition: color .2s; }
	nav a:hover, nav a:focus-visible, nav a:active, .footer-links a:hover { color: var(--red-primary); }

	.button { min-height: 56px; padding: 0 24px; border: 1px solid var(--red-primary); border-radius: 9px; background: var(--red-primary); color: white; display: inline-flex; align-items: center; justify-content: center; gap: 22px; font-size: 13px; font-weight: 750; cursor: pointer; transition: background .2s, transform .2s, border-color .2s; }
	.button:hover { background: var(--red-deep); border-color: var(--red-deep); transform: translateY(-2px); }
	.button span { font-size: 16px; }
	.button-small { min-height: 42px; padding: 0 17px; gap: 14px; font-size: 12px; }
	.text-link { display: inline-block; padding: 10px 0 7px; border-bottom: 1px solid var(--red-primary); color: var(--red-deep); font-size: 13px; font-weight: 750; }
	.text-link span { margin-left: 9px; }
	.text-link:hover { color: var(--red-bright); border-color: var(--red-bright); }

	.hero { min-height: 800px; padding: 155px clamp(24px, 7vw, 110px) 90px; display: grid; grid-template-columns: minmax(0, 1fr) minmax(440px, .92fr); gap: 5vw; overflow: hidden; }
	.hero-copy { z-index: 2; max-width: 680px; align-self: center; padding-bottom: 32px; }
	.eyebrow, .kicker { margin: 0 0 26px; color: var(--red-deep); font-size: 11px; font-weight: 750; letter-spacing: 1.55px; text-transform: uppercase; }
	.eyebrow { display: flex; align-items: center; gap: 10px; }
	.eyebrow span { width: 8px; height: 8px; border-radius: 50%; background: var(--red-bright); box-shadow: 0 0 0 5px var(--red-soft); }
	h1, h2 { margin: 0; font-family: var(--serif); font-weight: 500; line-height: .98; letter-spacing: -3.8px; }
	h1 { font-size: clamp(62px, 6.7vw, 100px); }
	h1 em, h2 em { color: var(--red-deep); font-weight: 400; }
	.hero-lede { max-width: 590px; margin: 31px 0; color: var(--charcoal); font-size: 18px; line-height: 1.7; }
	.hero-actions { display: flex; align-items: center; gap: 28px; }
	.microcopy { margin: 18px 0 0; color: var(--muted); font-size: 10px; font-weight: 650; letter-spacing: .25px; }
	.microcopy span { margin-right: 6px; color: var(--red-primary); }

	.product-stage { position: relative; min-height: 610px; display: grid; place-items: center; }
	.product-stage::before { content: ""; position: absolute; width: 480px; height: 480px; border-radius: 45% 55% 58% 42%; background: var(--red-soft); transform: rotate(-8deg); }
	.hero-brand-symbol { position: absolute; z-index: 1; top: 55px; left: 4%; opacity: .12; transform: rotate(-8deg); }
	.halo { position: absolute; border: 1px solid rgba(201, 54, 62, .16); border-radius: 50%; }
	.halo-one { width: 580px; height: 580px; }
	.halo-two { width: 720px; height: 720px; }
	.phone { z-index: 2; position: relative; width: 310px; height: 635px; padding: 10px 18px; overflow: hidden; border: 7px solid var(--charcoal); border-radius: 45px; background: var(--white); box-shadow: 0 35px 75px rgba(143, 31, 40, .18); transform: rotate(1.3deg); }
	.phone-top { height: 27px; display: flex; align-items: center; justify-content: space-between; font-size: 8px; font-weight: 750; }
	.phone-top b { width: 76px; height: 18px; border-radius: 20px; background: var(--charcoal); }
	.app-head { margin: 15px 0; display: flex; align-items: center; justify-content: space-between; }
	.app-head small, .day-summary small, .checkin-card small { color: var(--muted); font-size: 7px; font-weight: 750; letter-spacing: 1px; }
	.app-head h2 { margin-top: 5px; font-family: var(--sans); font-size: 27px; font-weight: 700; letter-spacing: -1.3px; }
	.avatar { width: 35px; height: 35px; display: grid; place-items: center; border-radius: 50%; background: var(--red-soft); color: var(--red-deep); font-size: 10px; font-weight: 800; }
	.day-summary { padding: 14px; border: 1px solid var(--border); border-radius: 15px; background: white; display: grid; grid-template-columns: 43px 1fr auto; align-items: center; gap: 12px; }
	.day-summary > span { width: 43px; height: 43px; display: grid; place-items: center; border-radius: 12px; background: var(--red-primary); color: white; font-family: var(--serif); font-size: 22px; }
	.day-summary strong { display: block; margin-top: 4px; font-size: 10px; }
	.day-summary i { color: var(--muted); font-style: normal; font-size: 8px; letter-spacing: 1px; }
	.timeline-label { margin: 20px 0 8px; display: flex; justify-content: space-between; font-size: 11px; }
	.timeline-label span { color: var(--red-primary); font-size: 8px; font-weight: 750; }
	.timeline { position: relative; }
	.timeline::before { content: ""; position: absolute; top: 22px; bottom: 22px; left: 57px; width: 1px; background: var(--border); }
	.timeline-row { position: relative; min-height: 63px; display: grid; grid-template-columns: 42px 14px 1fr auto; align-items: center; gap: 9px; border-bottom: 1px solid var(--border); }
	.time strong, .time small, .timeline-name strong, .timeline-name small { display: block; }
	.time strong { font-size: 10px; }
	.time small, .timeline-name small { margin-top: 3px; color: var(--muted); font-size: 7px; }
	.timeline-node { z-index: 1; width: 13px; height: 13px; display: grid; place-items: center; border: 2px solid white; border-radius: 50%; box-shadow: 0 0 0 1px var(--border); font-size: 7px; font-weight: 800; color: white; }
	.timeline-node.deep { background: var(--red-deep); }
	.timeline-node.primary { background: var(--red-primary); }
	.timeline-node.bright { background: var(--red-bright); }
	.timeline-node.upcoming { background: var(--white); border-color: var(--white); color: var(--red-bright); }
	.timeline-name strong { font-size: 10px; }
	.timeline-row button { padding: 5px 0; border: 0; background: transparent; color: var(--muted); font-size: 8px; cursor: pointer; }
	.checkin-card { margin-top: 15px; padding: 14px; border-radius: 15px; background: var(--red-soft); }
	.checkin-card strong { display: block; margin-top: 4px; font-size: 11px; }
	.checkin-tags { margin-top: 11px; display: flex; gap: 6px; }
	.checkin-tags span { padding: 6px 8px; border: 1px solid var(--border); border-radius: 20px; background: rgba(255, 255, 255, .72); font-size: 7px; }
	.app-nav { position: absolute; right: 0; bottom: 0; left: 0; height: 62px; padding: 0 14px; border-top: 1px solid var(--border); background: white; display: flex; align-items: center; justify-content: space-around; }
	.app-nav span { display: grid; place-items: center; gap: 4px; color: var(--muted); font-size: 13px; }
	.app-nav small { font-size: 6px; }
	.app-nav .selected { color: var(--red-primary); }
	.context-card { position: absolute; z-index: 4; min-width: 205px; padding: 15px 17px; display: flex; align-items: center; gap: 12px; border: 1px solid var(--border); border-radius: 13px; background: rgba(255, 255, 255, .96); box-shadow: var(--shadow); }
	.context-card small, .context-card strong { display: block; }
	.context-card small { margin-bottom: 4px; color: var(--muted); font-size: 7px; font-weight: 800; letter-spacing: .8px; }
	.context-card strong { font-size: 10px; }
	.context-icon { width: 34px; height: 34px; display: grid; place-items: center; border-radius: 50%; background: var(--red-soft); color: var(--red-primary); font-size: 16px; }
	.cycle-card { top: 130px; right: -4px; }
	.privacy-card { bottom: 95px; left: -16px; }

	.principles { min-height: 82px; padding: 0 clamp(24px, 7vw, 110px); background: var(--red-deep); color: white; display: grid; grid-template-columns: repeat(3, 1fr); align-items: stretch; }
	.principles p { margin: 0; padding: 26px 5vw 26px 0; display: flex; align-items: center; gap: 15px; border-right: 1px solid rgba(255,255,255,.14); font-size: 11px; font-weight: 650; letter-spacing: .25px; }
	.principles p + p { padding-left: 5vw; }
	.principles p:last-child { border-right: 0; }
	.principles span { color: #ffffff; font-family: var(--serif); font-size: 12px; }

	.section { padding: 120px clamp(24px, 7vw, 110px); }
	.section-intro { display: grid; grid-template-columns: 1.25fr .75fr; gap: 80px; align-items: end; }
