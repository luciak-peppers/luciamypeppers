---
type IconName =
	| 'peptide'
	| 'prescription'
	| 'mental-health'
	| 'supplement'
	| 'symptoms'
	| 'cycle'
	| 'menopause'
	| 'sleep'
	| 'mood'
	| 'appointment'
	| 'privacy';

interface Props {
	name: IconName;
	size?: number;
	label?: string;
	class?: string;
}

const { name, size = 24, label, class: className } = Astro.props;
---

<svg
	class:list={['line-icon-svg', className]}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.65"
	stroke-linecap="round"
	stroke-linejoin="round"
	role={label ? 'img' : undefined}
	aria-label={label}
	aria-hidden={label ? undefined : 'true'}
>
	{name === 'peptide' && <><path d="M8 3.5h8v4l2 3v8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-8l2-3v-4Z"/><path d="M8 7.5h8M9 14h6"/></>}
	{name === 'prescription' && <><rect x="7" y="3.5" width="10" height="17" rx="5"/><path d="M8.5 9.5h7"/></>}
	{name === 'mental-health' && <><path d="M12 20.5c4.7 0 8.5-3.7 8.5-8.3S16.7 4 12 4 3.5 7.7 3.5 12.2c0 2.2.9 4.2 2.4 5.7L5.4 21l3.3-1.3c1 .5 2.1.8 3.3.8Z"/><path d="M8 12h2l1.2-2.6 2.2 5.2 1.2-2.6H17"/></>}
	{name === 'supplement' && <><path d="M6.1 17.9a4 4 0 0 1 0-5.7l6.1-6.1a4 4 0 0 1 5.7 5.7l-6.1 6.1a4 4 0 0 1-5.7 0Z"/><path d="m9.2 9.2 5.6 5.6"/></>}
	{name === 'symptoms' && <><path d="M3 12h4l2.2-5 4.1 10 2.2-5H21"/><circle cx="12" cy="12" r="9" opacity=".28"/></>}
	{name === 'cycle' && <><path d="M20 11a8 8 0 1 0-2.3 5.7"/><path d="M20 5v6h-6"/></>}
	{name === 'menopause' && <><path d="M5 16c2.3-5 4.7-7.5 7-7.5S16.7 11 19 16"/><path d="M7 11.5c1.6-4 3.3-6 5-6s3.4 2 5 6M12 5.5V3"/></>}
	{name === 'sleep' && <><path d="M19 15.5A8 8 0 0 1 8.5 5 8 8 0 1 0 19 15.5Z"/><path d="m16.5 4 .6 1.4 1.4.6-1.4.6-.6 1.4-.6-1.4-1.4-.6 1.4-.6.6-1.4Z"/></>}
	{name === 'mood' && <><circle cx="12" cy="12" r="9"/><path d="M8.5 10h.01M15.5 10h.01M8.5 15c2.2 1.6 4.8 1.6 7 0"/></>}
	{name === 'appointment' && <><path d="M6 4h12v17H6z"/><path d="M9 3v3M15 3v3M6 9h12M9 13h6M9 17h4"/></>}
	{name === 'privacy' && <><path d="M12 3.5 19 6v5c0 4.7-2.6 7.8-7 9.5-4.4-1.7-7-4.8-7-9.5V6l7-2.5Z"/><path d="m9 12 2 2 4-4"/></>}
</svg>

<style>
	.line-icon-svg { display: block; color: inherit; }
</style>
